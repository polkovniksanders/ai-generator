generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int      @id @default(autoincrement())
  uuid        String   @unique @default(uuid())
  name        String
  surname     String
  age         Int
  profession  String?
  description String?
  image       String?
  createdAt   DateTime @default(now())
}
